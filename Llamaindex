import pyarrow.parquet as pq
import numpy as np

for sid in all_indices:
    raw = pq.read_metadata(f"labeled_shard{sid}.parquet").num_rows
    try:
        enc = np.load(f"enriched_shard{sid}.npz")["features"].shape[0]
    except:
        enc = -1
    if enc != raw:
        print(f"shard {sid}: raw={raw}, enriched={enc}")
